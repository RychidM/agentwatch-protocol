{
  "name": "@agent-watch/protocol",
  "version": "0.1.6",
  "description": "Type definitions and JSON schema validators for the AgentWatch protocol",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./v2": {
      "types": "./dist/v2.d.ts",
      "default": "./dist/v2.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test test/**/*.test.cjs"
  },
  "keywords": [
    "agentwatch",
    "protocol",
    "types",
    "schema"
  ],
  "author": "AgentWatch contributors",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.5"
  }
}
