{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "push.schema.json",
  "$defs": {
    "PushPayload": {
      "type": "object",
      "title": "PushPayload",
      "description": "Relay envelope for encrypted messages",
      "additionalProperties": false,
      "required": [
        "type",
        "pairingId",
        "encryptedBlob"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "approval_request",
            "session_start",
            "session_end",
            "subscription_event"
          ]
        },
        "sessionId": {
          "type": "string",
          "maxLength": 255
        },
        "pairingId": {
          "type": "string",
          "maxLength": 255
        },
        "encryptedBlob": {
          "type": "string",
          "maxLength": 1048576
        }
      }
    }
  }
}
