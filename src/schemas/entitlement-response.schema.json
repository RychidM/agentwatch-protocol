{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "entitlement-response.schema.json",
  "type": "object",
  "title": "EntitlementResponse",
  "description": "Response to an entitlement check",
  "additionalProperties": false,
  "required": [
    "decision",
    "count",
    "limit",
    "resetDate"
  ],
  "properties": {
    "decision": {
      "type": "string",
      "enum": [
        "allowed",
        "denied",
        "soft_limit_warning"
      ]
    },
    "errorCode": {
      "type": "string",
      "enum": [
        "limit_exceeded",
        "plan_downgraded",
        "account_suspended",
        "invalid_pairing"
      ]
    },
    "count": {
      "type": "integer",
      "minimum": 0
    },
    "limit": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "resetDate": {
      "type": "string",
      "format": "date-time",
      "maxLength": 64
    }
  }
}
