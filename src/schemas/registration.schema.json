{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "registration.schema.json",
  "type": "object",
  "title": "DeviceRegistration",
  "description": "Phone app registration data",
  "additionalProperties": false,
  "required": [
    "deviceToken",
    "platform",
    "sessionId",
    "pairingId"
  ],
  "properties": {
    "deviceToken": {
      "type": "string",
      "description": "FCM or APNs device token",
      "maxLength": 1024
    },
    "platform": {
      "type": "string",
      "description": "Platform type",
      "enum": [
        "ios",
        "android"
      ]
    },
    "sessionId": {
      "type": "string",
      "description": "Session ID to subscribe to",
      "maxLength": 255
    },
    "pairingId": {
      "type": "string",
      "description": "Pairing ID for device linkage",
      "maxLength": 255
    }
  }
}