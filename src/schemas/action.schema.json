{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "action.schema.json",
  "$defs": {
    "AgentAction": {
      "type": "object",
      "title": "AgentAction",
      "description": "A single agent tool call",
      "additionalProperties": false,
      "required": [
        "id",
        "sessionId",
        "toolName",
        "input",
        "summary",
        "tier",
        "timestamp"
      ],
      "properties": {
        "id": {
          "type": "string",
          "maxLength": 255
        },
        "sessionId": {
          "type": "string",
          "maxLength": 255
        },
        "toolName": {
          "type": "string",
          "maxLength": 255
        },
        "input": {
          "type": "object"
        },
        "summary": {
          "type": "string",
          "maxLength": 2048
        },
        "tier": {
          "type": "string",
          "enum": [
            "read",
            "write",
            "run"
          ]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "maxLength": 64
        },
        "outcome": {
          "type": "string",
          "enum": [
            "allowed",
            "denied",
            "auto_approved"
          ]
        },
        "autoApprovalRecord": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "reason",
            "limitType",
            "resetDate"
          ],
          "properties": {
            "reason": {
              "type": "string",
              "enum": [
                "limit_reached"
              ]
            },
            "limitType": {
              "type": "string",
              "enum": [
                "daily",
                "monthly"
              ]
            },
            "resetDate": {
              "type": "string",
              "format": "date-time",
              "maxLength": 64
            }
          }
        }
      }
    }
  }
}
