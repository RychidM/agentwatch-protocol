{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "action.schema.json",
  "$defs": {
    "AgentAction": {
      "type": "object",
      "title": "AgentAction",
      "description": "A single agent tool call",
      "additionalProperties": false,
      "required": [
        "id",
        "sessionId",
        "toolName",
        "input",
        "summary",
        "tier",
        "hasNonAsciiWarning",
        "timestamp"
      ],
      "properties": {
        "id": {
          "type": "string",
          "maxLength": 255
        },
        "sessionId": {
          "type": "string",
          "maxLength": 255
        },
        "toolName": {
          "type": "string",
          "maxLength": 255
        },
        "input": {
          "type": "object"
        },
        "summary": {
          "type": "string",
          "maxLength": 2048
        },
        "tier": {
          "type": "string",
          "enum": [
            "observe",
            "approval"
          ]
        },
        "hasNonAsciiWarning": {
          "type": "boolean"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "maxLength": 64
        }
      }
    },
    "ApprovalContextAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "toolName",
        "summary"
      ],
      "properties": {
        "toolName": {
          "type": "string",
          "maxLength": 255
        },
        "summary": {
          "type": "string",
          "maxLength": 2048
        }
      }
    },
    "ResolvedBy": {
      "type": "string",
      "enum": [
        "phone",
        "ide",
        "ide_limit_fallback",
        "ide_disconnected",
        "timeout"
      ]
    }
  }
}