{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "HookOutput",
  "description": "Hook response to IDE",
  "additionalProperties": false,
  "required": ["decision"],
  "properties": {
    "decision": {
      "type": "string",
      "description": "Decision for the hook event",
      "enum": ["allow", "deny"]
    },
    "reason": {
      "type": "string",
      "description": "Optional reason for denial",
      "maxLength": 2048
    }
  }
}
