{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentwatch.dev/schemas/messages.schema.json",
  "title": "Messages",
  "description": "Message (envelope) type definitions for the AgentWatch protocol.",
  "definitions": {
    "MessageType": {
      "$id": "#/definitions/MessageType",
      "type": "string",
      "enum": ["request", "response", "notification"],
      "description": "Discriminant string literals for all top-level message types."
    },
    "ResponseStatus": {
      "$id": "#/definitions/ResponseStatus",
      "type": "string",
      "enum": ["ok", "error"],
      "description": "Outcome of processing a RequestMessage."
    },
    "BaseMessage": {
      "$id": "#/definitions/BaseMessage",
      "type": "object",
      "description": "Fields common to every message.",
      "required": ["messageId", "type", "protocolVersion", "sentAt"],
      "properties": {
        "messageId": {
          "$ref": "common.schema.json#/definitions/Uuid",
          "description": "Unique message identifier."
        },
        "type": {
          "$ref": "#/definitions/MessageType",
          "description": "Discriminant field that identifies the concrete message shape."
        },
        "protocolVersion": {
          "$ref": "common.schema.json#/definitions/ProtocolVersion",
          "description": "Protocol version used by the sender."
        },
        "sentAt": {
          "$ref": "common.schema.json#/definitions/Timestamp",
          "description": "ISO 8601 timestamp when the message was created."
        }
      }
    },
    "RequestMessage": {
      "$id": "#/definitions/RequestMessage",
      "allOf": [
        { "$ref": "#/definitions/BaseMessage" },
        {
          "type": "object",
          "description": "A request sent from a client to the AgentWatch observer.",
          "required": ["type", "correlationId", "action"],
          "additionalProperties": false,
          "properties": {
            "messageId": {},
            "type": { "type": "string", "const": "request" },
            "protocolVersion": {},
            "sentAt": {},
            "correlationId": {
              "$ref": "common.schema.json#/definitions/Uuid",
              "description": "Identifier used to correlate the response."
            },
            "action": {
              "type": "string",
              "description": "The action the sender wants performed."
            },
            "payload": {
              "type": "object",
              "description": "Action-specific payload."
            }
          }
        }
      ]
    },
    "ResponseMessage": {
      "$id": "#/definitions/ResponseMessage",
      "allOf": [
        { "$ref": "#/definitions/BaseMessage" },
        {
          "type": "object",
          "description": "A response returned from the observer in reply to a RequestMessage.",
          "required": ["type", "correlationId", "status"],
          "additionalProperties": false,
          "properties": {
            "messageId": {},
            "type": { "type": "string", "const": "response" },
            "protocolVersion": {},
            "sentAt": {},
            "correlationId": {
              "$ref": "common.schema.json#/definitions/Uuid",
              "description": "Matches the correlationId of the originating request."
            },
            "status": {
              "$ref": "#/definitions/ResponseStatus",
              "description": "Indicates whether the request succeeded."
            },
            "result": {
              "type": "object",
              "description": "Response body on success."
            },
            "error": {
              "type": "object",
              "required": ["code", "message"],
              "additionalProperties": false,
              "properties": {
                "code": { "type": "string" },
                "message": { "type": "string" }
              },
              "description": "Error detail on failure."
            }
          }
        }
      ]
    },
    "NotificationMessage": {
      "$id": "#/definitions/NotificationMessage",
      "allOf": [
        { "$ref": "#/definitions/BaseMessage" },
        {
          "type": "object",
          "description": "A push notification carrying one or more agent events.",
          "required": ["type", "events"],
          "additionalProperties": false,
          "properties": {
            "messageId": {},
            "type": { "type": "string", "const": "notification" },
            "protocolVersion": {},
            "sentAt": {},
            "events": {
              "type": "array",
              "items": { "$ref": "events.schema.json#/definitions/AgentEvent" },
              "minItems": 1,
              "description": "One or more events bundled in this notification."
            }
          }
        }
      ]
    },
    "Message": {
      "$id": "#/definitions/Message",
      "description": "Discriminated union of all concrete message types.",
      "oneOf": [
        { "$ref": "#/definitions/RequestMessage" },
        { "$ref": "#/definitions/ResponseMessage" },
        { "$ref": "#/definitions/NotificationMessage" }
      ]
    }
  }
}
