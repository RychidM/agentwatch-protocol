{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "heartbeat.schema.json",
  "type": "object",
  "title": "SessionHeartbeat",
  "description": "Keep-alive signal for an active session",
  "additionalProperties": false,
  "required": ["sessionId"],
  "properties": {
    "sessionId": {
      "type": "string",
      "description": "Session to keep alive",
      "minLength": 1,
      "maxLength": 128
    }
  }
}
